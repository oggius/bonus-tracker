{
  "name": "@bonus-tracker/db",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "node_modules/.bin/tsx prisma/seed.ts"
  },
  "scripts": {
    "build": "pnpm run db:generate && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'db lint'",
    "prisma": "prisma",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "prisma": "^6.7.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}