# PostgreSQL connection used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bonus_tracker"

# Session JWT signing secret (must be set in production)
SESSION_SECRET="replace-with-a-long-random-secret"

# Stable key for Next.js Server Actions encryption
# Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="replace-with-a-stable-32-byte-base64-key"
